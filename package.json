{
  "name": "pp-bot",
  "version": "1.0.0",
  "description": "Discord bot that tracks PrizePicks NBA prop line movement and posts analytics.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "grade": "node grade_props.js",
    "grade:full": "npm run grade && npm run recap",
    "recap": "node post_recap.js",
    "context:refresh": "python refresh_team_context.py",
    "archive": "node archive_props.js",
    "projection:report": "python projection_report.py",
    "projection:confrontation": "python projection_confrontation_report.py",
    "smoke": "node --check index.js",
    "smoke:grade": "node --check grade_props.js",
    "smoke:recap": "node --check post_recap.js",
    "smoke:archive": "node --check archive_props.js",
    "smoke:projection": "python -m py_compile nba_stats.py projection_report.py projection_confrontation_report.py",
    "smoke:context": "python -m py_compile refresh_team_context.py team_context.py nba_stats.py",
    "test:projection": "python -m unittest discover -s tests -p test_projection*.py",
    "test": "npm run smoke && npm run smoke:grade && npm run smoke:recap && npm run smoke:archive && npm run smoke:projection && npm run smoke:context && npm run test:projection"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cheerio": "^1.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "node-fetch": "^2.7.0",
    "nba-api-ts": "latest",
    "tlsclientwrapper": "latest"
  }
}
